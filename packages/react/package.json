{
    "name": "@docmosaic/react",
    "version": "0.1.0",
    "private": false,
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        },
        "./styles.css": "./dist/styles.css",
        "./styles/base.css": "./dist/styles/base.css",
        "./styles/themes/docmosaic.css": "./dist/styles/themes/docmosaic.css",
        "./styles/themes/minimal-dark.css": "./dist/styles/themes/minimal-dark.css",
        "./styles/themes/minimal-light.css": "./dist/styles/themes/minimal-light.css"
    },
    "sideEffects": [
        "**/*.css"
    ],
    "files": [
        "dist"
    ],
    "engines": {
        "node": ">=18.18.0"
    },
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "typecheck": "tsc --noEmit",
        "lint": "eslint src --max-warnings=0",
        "test": "vitest",
        "test:run": "vitest run --passWithNoTests"
    },
    "peerDependencies": {
        "@docmosaic/core": "workspace:*",
        "react": "^19",
        "react-dom": "^19"
    },
    "dependencies": {
        "@radix-ui/react-dialog": "^1.1.6",
        "@radix-ui/react-scroll-area": "^1.2.3",
        "@radix-ui/react-select": "^2.1.6",
        "@radix-ui/react-slot": "^1.1.2",
        "@use-gesture/react": "^10.3.1",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "lucide-react": "^0.475.0",
        "react-dnd": "^16.0.1",
        "react-dnd-html5-backend": "^16.0.1",
        "react-hot-toast": "^2.5.2",
        "tailwind-merge": "^3.0.1"
    },
    "devDependencies": {
        "@docmosaic/core": "workspace:*",
        "@eslint/js": "^9.39.4",
        "@testing-library/jest-dom": "^6.6.3",
        "@testing-library/react": "^16.2.0",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "@vitejs/plugin-react": "^6.0.2",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^5.2.0",
        "happy-dom": "^20.10.2",
        "react": "^19",
        "react-dom": "^19",
        "tsup": "^8.3.5",
        "typescript": "^5.6.3",
        "typescript-eslint": "^8.60.1",
        "vitest": "^4.1.8"
    }
}
