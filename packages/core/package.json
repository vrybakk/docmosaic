{
    "name": "@docmosaic/core",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "sideEffects": false,
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "typecheck": "tsc --noEmit",
        "lint": "echo \"no-op (TODO: tighten in Phase 10)\"",
        "test": "vitest",
        "test:run": "vitest run --passWithNoTests"
    },
    "dependencies": {
        "jspdf": "^2.5.2",
        "uuid": "^11.0.5"
    },
    "devDependencies": {
        "@types/node": "^20",
        "@types/uuid": "^10.0.0",
        "tsup": "^8.3.5",
        "typescript": "^5.6.3",
        "vitest": "^2.1.8"
    }
}
